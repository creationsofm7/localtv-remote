{
  "name": "localtv-remote",
  "version": "0.1.1",
  "description": "Control your Windows PC from your phone — free, open-source wireless mouse, keyboard & volume remote over Wi-Fi. No app to install on the phone, multi-user, LAN-only.",
  "license": "Apache-2.0",
  "private": false,
  "main": "dist/daemon/index.js",
  "bin": {
    "localtv-remote": "dist/daemon/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/daemon/index.js",
    "dev": "tsx src/daemon/index.ts",
    "bundle": "node scripts/bundle.mjs",
    "build:sea": "node scripts/build-sea.mjs",
    "payload": "node scripts/assemble-payload.mjs",
    "dist": "npm run typecheck && npm run bundle && npm run build:sea && npm run payload",
    "installer": "node scripts/build-installer.mjs"
  },
  "dependencies": {
    "express": "^5.2.1",
    "koffi": "^2.15.2",
    "qrcode": "^1.5.4",
    "ws": "^8.18.3"
  },
  "optionalDependencies": {
    "node-audio-volume-mixer": "^1.0.3",
    "systray2": "^2.1.0",
    "webview-nodejs": "^0.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6",
    "rcedit": "^5.0.2",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5"
  }
}
